generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Cashier {
  id        Int               @id @default(autoincrement())
  name      String
  pin       String
  isActive  Boolean           @default(true)
  createdAt DateTime          @default(now())
  sessions  CashierSession[]
  transactions Transaction[]
}

model CashierSession {
  id           Int       @id @default(autoincrement())
  cashier      Cashier   @relation(fields: [cashierId], references: [id])
  cashierId    Int
  startCash    Float
  endCash      Float?
  status       String    @default("OPEN")
  openedAt     DateTime  @default(now())
  closedAt     DateTime?
  transactions Transaction[]
}

model Category {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  emoji    String
  color    String
  products Product[]
}

model BundleItem {
  id        Int     @id @default(autoincrement())
  bundleId  Int
  productId Int
  qty       Int
  bundle    Product @relation("BundleToItems", fields: [bundleId], references: [id], onDelete: Cascade)
  product   Product @relation("ProductToBundleItems", fields: [productId], references: [id], onDelete: Cascade)

  @@unique([bundleId, productId])
}

model Product {
  id               Int               @id @default(autoincrement())
  name             String
  description      String?
  price            Float
  emoji            String            @default("🍧")
  image            String?
  category         Category          @relation(fields: [categoryId], references: [id])
  categoryId       Int
  stock            Int?
  isActive         Boolean           @default(true)
  createdAt        DateTime          @default(now())
  transactionItems TransactionItem[]
  stockWastes      StockWaste[]
  stockReceiptItems StockReceiptItem[]
  stockOpnameItems  StockOpnameItem[]
  stockMovements    StockMovement[]

  // Relations for bundling
  bundleItems       BundleItem[]       @relation("BundleToItems")
  includedInBundles BundleItem[]       @relation("ProductToBundleItems")
}

model Transaction {
  id              Int               @id @default(autoincrement())
  invoiceNumber   String            @unique
  cashier         Cashier           @relation(fields: [cashierId], references: [id])
  cashierId       Int
  session         CashierSession    @relation(fields: [sessionId], references: [id])
  sessionId       Int
  items           TransactionItem[]
  subtotal        Float
  discountAmount  Float             @default(0)
  total           Float
  paymentMethod   String
  amountPaid      Float
  change          Float             @default(0)
  status          String            @default("COMPLETED")
  note            String?
  createdAt       DateTime          @default(now())
}

model TransactionItem {
  id            Int         @id @default(autoincrement())
  transaction   Transaction @relation(fields: [transactionId], references: [id])
  transactionId Int
  product       Product     @relation(fields: [productId], references: [id])
  productId     Int
  productName   String
  productPrice  Float
  qty           Int
  discount      Float       @default(0)
  subtotal      Float
}

model StockWaste {
  id        Int      @id @default(autoincrement())
  product   Product  @relation(fields: [productId], references: [id])
  productId Int
  qty       Int
  reason    String
  note      String?
  createdAt DateTime @default(now())
}


model Supplier {
  id            Int             @id @default(autoincrement())
  name          String
  contactPerson  String?
  phone         String?
  address       String?
  isActive      Boolean         @default(true)
  createdAt     DateTime        @default(now())
  receipts      StockReceipt[]
}

model Warehouse {
  id          Int             @id @default(autoincrement())
  name        String
  code        String          @unique
  location    String?
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  receipts    StockReceipt[]
  opnames     StockOpname[]
  movements   StockMovement[]
}

model StockReceipt {
  id            Int                @id @default(autoincrement())
  receiptNumber String             @unique
  supplier      Supplier?          @relation(fields: [supplierId], references: [id])
  supplierId    Int?
  warehouse     Warehouse?         @relation(fields: [warehouseId], references: [id])
  warehouseId   Int?
  receiptDate   DateTime           @default(now())
  documentNo    String?
  status        String             @default("DRAFT")
  note          String?
  totalAmount   Float              @default(0)
  createdAt     DateTime           @default(now())
  items         StockReceiptItem[]
}

model StockReceiptItem {
  id             Int          @id @default(autoincrement())
  receipt        StockReceipt @relation(fields: [receiptId], references: [id])
  receiptId      Int
  product        Product      @relation(fields: [productId], references: [id])
  productId      Int
  qty            Int
  unitPrice      Float        @default(0)
  subtotal       Float        @default(0)
}

model StockOpname {
  id           Int              @id @default(autoincrement())
  opnameNumber String           @unique
  warehouse    Warehouse?       @relation(fields: [warehouseId], references: [id])
  warehouseId  Int?
  opnameDate   DateTime         @default(now())
  status       String           @default("DRAFT")
  note         String?
  createdAt    DateTime         @default(now())
  items        StockOpnameItem[]
}

model StockOpnameItem {
  id            Int         @id @default(autoincrement())
  opname        StockOpname @relation(fields: [opnameId], references: [id])
  opnameId      Int
  product       Product     @relation(fields: [productId], references: [id])
  productId     Int
  systemStock   Int
  physicalStock Int
  difference    Int
  reason        String?
}

model StockMovement {
  id          Int       @id @default(autoincrement())
  product     Product   @relation(fields: [productId], references: [id])
  productId   Int
  warehouse   Warehouse? @relation(fields: [warehouseId], references: [id])
  warehouseId Int?
  type        String
  refType     String?
  refId       Int?
  qtyIn       Int       @default(0)
  qtyOut      Int       @default(0)
  note        String?
  createdAt   DateTime  @default(now())
}

model StoreSetting {
  id          Int      @id @default(autoincrement())
  name        String
  logo        String?
  address     String?
  phone       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}